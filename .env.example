# 股票追蹤與決策輔助系統 V1 - 環境變數設定範例
# Stock Tracking & Decision Support System V1 - Environment Variables Example

# 資料庫配置
DATABASE_PATH=data/stocks.db

# Telegram 配置（選擇性）
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# CSV 資料檔案路徑
SAMPLE_STOCKS_CSV=data/sample_stocks.csv
SAMPLE_PRICES_CSV=data/sample_prices.csv
SAMPLE_FUNDAMENTALS_CSV=data/sample_fundamentals.csv

# FinMind 真實資料源（免費 token：https://finmindtrade.com/）
FINMIND_TOKEN=your_finmind_token_here
# 資料庫無資料時往回抓的天數
DATA_UPDATE_LOOKBACK_DAYS=180

# 回測配置
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_RISK_FREE_RATE=0.02

# Streamlit 配置
STREAMLIT_PORT=8501
# 預設僅監聽本機；需區網存取時改為 0.0.0.0
STREAMLIT_HOST=127.0.0.1

# 日誌設定
LOG_LEVEL=INFO
LOG_FILE=logs/app.log